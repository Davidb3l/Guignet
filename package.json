{
  "name": "guignet",
  "version": "0.0.1",
  "description": "The referee — private benchmarking of AI coding agents on your own repo.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "guignet": "./src/bin/guignet.ts"
  },
  "scripts": {
    "guignet": "bun run src/bin/guignet.ts",
    "typecheck": "tsc --noEmit",
    "check:boundaries": "bun run scripts/check-boundaries.ts",
    "test": "bun test",
    "check": "bun run typecheck && bun run check:boundaries && bun test"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/bun": "^1.3.0"
  }
}
